{
  "name": "vibetunnel",
  "version": "1.0.0-beta.17",
  "description": "Terminal sharing server with web interface - supports macOS, Linux, and headless environments",
  "main": "dist/server/server.js",
  "bin": {
    "vibetunnel": "./bin/vibetunnel"
  },
  "files": [
    "dist/",
    "public/",
    "bin/",
    "forwarders/",
    "scripts/ensure-native-modules.js",
    "scripts/postinstall-npm.js",
    "scripts/install-vt-command.js",
    "node-pty/lib/",
    "node-pty/package.json",
    "node-pty/binding.gyp",
    "node-pty/src/",
    "node-pty/tsconfig.json",
    "prebuilds/",
    "README.md"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "engines": {
    "node": ">=22.12.0 <25"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/amantus-ai/vibetunnel.git",
    "directory": "web"
  },
  "homepage": "https://vibetunnel.sh",
  "bugs": {
    "url": "https://github.com/amantus-ai/vibetunnel/issues"
  },
  "scripts": {
    "clean": "node scripts/clean.js",
    "dev": "node scripts/dev.js",
    "dev:mobile": "node scripts/dev.js --bind 0.0.0.0 --port 4021",
    "dev:server": "tsx watch src/cli.ts --no-auth",
    "dev:client": "node scripts/dev.js --client-only",
    "build": "node scripts/build.js",
    "build:ci": "node scripts/build-ci.js",
    "build:npm": "node scripts/build-npm.js",
    "prepublishOnly": "npm run build:npm",
    "postinstall": "node scripts/postinstall-npm.js",
    "prebuild": "echo 'Skipping prebuild - handled by build-npm.js'",
    "prebuild:upload": "echo 'Skipping prebuild:upload - not used'",
    "lint": "biome check src",
    "lint:fix": "biome check src --write",
    "lint:biome": "pnpm run lint",
    "lint:typeaware": "./scripts/lint-typeaware.sh",
    "typecheck": "concurrently -n server,client,sw \"tsc --noEmit --project tsconfig.server.json\" \"tsc --noEmit --project tsconfig.client.json\" \"tsc --noEmit --project tsconfig.sw.json\"",
    "test:prepare": "node scripts/ensure-native-modules.js && node scripts/ensure-test-cli.js",
    "pretest": "pnpm run test:prepare",
    "test": "vitest",
    "pretest:ci": "pnpm run test:prepare",
    "test:ci": "vitest run --reporter=verbose",
    "pretest:coverage": "pnpm run test:prepare",
    "test:coverage": "vitest run --coverage",
    "pretest:client": "pnpm run test:prepare",
    "test:client": "vitest run --mode=client",
    "pretest:server": "pnpm run test:prepare",
    "test:server": "node scripts/copy-assets.js && vitest run --mode=server",
    "pretest:client:coverage": "pnpm run test:prepare",
    "test:client:coverage": "vitest run --mode=client --coverage",
    "pretest:server:coverage": "pnpm run test:prepare",
    "test:server:coverage": "node scripts/copy-assets.js && vitest run --mode=server --coverage",
    "format": "biome format src --write",
    "format:check": "biome format src",
    "prettier": "prettier --write src --experimental-cli",
    "prettier:check": "prettier --check src --experimental-cli",
    "prettier:fast": "PRETTIER_EXPERIMENTAL_CLI=1 prettier --write src",
    "check": "./scripts/check-all.sh",
    "check:fix": "./scripts/check-fix-sequential.sh",
    "test:vt": "./scripts/test-vt-syntax.sh",
    "precommit": "pnpm run format && pnpm run lint:fix && pnpm run typecheck",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:skip-failing": "playwright test --config=playwright.config.skip-failing.ts",
    "test:e2e:fast": "playwright test --config=playwright.config.fast.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:parallel": "PLAYWRIGHT_PARALLEL=true playwright test",
    "test:e2e:parallel:headed": "PLAYWRIGHT_PARALLEL=true playwright test --headed",
    "test:e2e:parallel:workers": "PLAYWRIGHT_PARALLEL=true PLAYWRIGHT_WORKERS=4 playwright test",
    "test:e2e:perf": "playwright test --config=playwright.config.performance.ts",
    "test:npm-package": "node scripts/test-npm-package.js",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "^3.4.11",
      "esbuild": "^0.28.1",
      "form-data": "^4.0.6",
      "js-yaml": "^4.2.0",
      "qs": "^6.15.2"
    },
    "onlyBuiltDependencies": [
      "authenticate-pam",
      "esbuild",
      "node-pty",
      "puppeteer"
    ]
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.1",
    "bonjour-service": "^1.3.0",
    "chalk": "^5.6.2",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "ghostty-web": "^0.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lit": "^3.3.2",
    "mime-types": "^3.0.2",
    "monaco-editor": "^0.55.1",
    "multer": "^2.2.0",
    "node-addon-api": "^8.7.0",
    "node-pty": "file:node-pty",
    "postject": "1.0.0-alpha.6",
    "signal-exit": "^4.1.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "authenticate-pam": "^1.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.59.1",
    "@prettier/plugin-oxc": "^0.1.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.6.2",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260510.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "chokidar": "^5.0.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.3",
    "dompurify": "^3.4.11",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "node-fetch": "^3.3.2",
    "oxlint": "^1.63.0",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.3",
    "puppeteer": "^24.43.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "vite": "8.0.16",
    "vitest": "^4.1.5",
    "ws-mock": "^0.1.0"
  },
  "keywords": [
    "terminal",
    "multiplexer",
    "websocket",
    "asciinema"
  ],
  "author": "",
  "license": "MIT",
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "biome check --write",
      "bash -c 'tsc --noEmit --project tsconfig.server.json'",
      "bash -c 'tsc --noEmit --project tsconfig.client.json'",
      "bash -c 'tsc --noEmit --project tsconfig.sw.json'"
    ],
    "../{ios,mac}/**/*.swift": [
      "bash -c 'cd ../ios && ./scripts/lint.sh'",
      "bash -c 'cd ../mac && ./scripts/lint.sh'"
    ]
  },
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b"
}
